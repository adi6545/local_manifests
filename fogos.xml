<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- Remote Repositories -->
  <remote name="lineage" fetch="https://github.com/LineageOS" />
  <remote name="muppets" fetch="https://github.com/TheMuppets" />

  <!-- Device Trees -->
  <project path="device/motorola/fogos" 
           name="android_device_motorola_fogos" 
           remote="lineage" />

  <project path="device/motorola/sm6375-common" 
           name="android_device_motorola_sm6375-common" 
           remote="lineage" />

  <!-- Kernel Source -->
  <project path="kernel/motorola/sm6375" 
           name="android_kernel_motorola_sm6375" 
           remote="lineage" />

  <!-- Hardware HALs & SEPolicy -->
  <project path="hardware/motorola" 
           name="android_hardware_motorola" 
           remote="lineage" />

  <!-- Vendor Blobs from The Muppets -->
  <project path="vendor/motorola/fogos" 
           name="proprietary_vendor_motorola_fogos" 
           remote="muppets" />

  <project path="vendor/motorola/sm6375-common" 
           name="proprietary_vendor_motorola_sm6375-common" 
           remote="muppets" />
</manifest>
